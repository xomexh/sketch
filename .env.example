# Sketch — Environment Configuration
#
# Copy this file to .env and edit as needed.
# LLM credentials, Slack tokens, and WhatsApp pairing are configured
# through the web UI during onboarding — not in this file.

# Database
# Supported: sqlite (default), postgres (planned)
DB_TYPE=sqlite
SQLITE_PATH=./data/sketch.db
# DATABASE_URL=postgres://user:pass@localhost:5432/sketch

# Server
# BASE_URL=https://sketch.yourcompany.com  # Used for email verification links; auto-detected from request headers if unset
DATA_DIR=./data
PORT=3000
LOG_LEVEL=info          # debug | info | warn | error

# Public-facing base URL (required for OAuth redirects)
# e.g. https://sketch.yourcompany.com — no trailing slash
# BASE_URL=http://localhost:3000
